{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://otcan.github.io/metabo-brief/models/pathway-model.schema.json",
  "title": "MetaboBrief explicit pathway model",
  "type": "object",
  "required": [
    "schemaVersion",
    "modelId",
    "modelVersion",
    "name",
    "pathway",
    "profileGroup",
    "algorithm",
    "variantContributionModelVersion",
    "compatiblePanelVersion",
    "biologicalQuestion",
    "negativePole",
    "positivePole",
    "defaultProfile",
    "minimumCoverage",
    "minimumIndependentSignals",
    "minimumEvidenceQuality",
    "maximumGroupContribution",
    "inputs",
    "interpretationBands",
    "limitations"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "modelId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "modelVersion": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "pathway": {
      "type": "string"
    },
    "profileGroup": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["experimental", "reviewed", "deprecated", "archived"]
    },
    "reviewLevel": {
      "type": "string",
      "enum": ["starter-reviewed", "expert-reviewed"]
    },
    "reviewedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "reviewChecklistVersion": {
      "type": "string"
    },
    "reviewNotes": {
      "type": "string"
    },
    "knownWeaknesses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "releaseUse": {
      "type": "string"
    },
    "algorithm": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "variantContributionModelVersion": {
      "type": "string"
    },
    "compatiblePanelVersion": {
      "type": "string"
    },
    "biologicalQuestion": {
      "type": "string"
    },
    "negativePole": {
      "type": "string"
    },
    "positivePole": {
      "type": "string"
    },
    "includedMechanisms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "excludedMechanisms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "defaultProfile": {
      "type": "string",
      "enum": ["conservative", "exploratory"]
    },
    "minimumCoverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "minimumIndependentSignals": {
      "type": "integer",
      "minimum": 1
    },
    "minimumEvidenceQuality": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "maximumGroupContribution": {
      "type": "number",
      "minimum": 0
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "rsid",
          "claimIds",
          "contributionStates",
          "axisMultiplier",
          "mechanism",
          "independenceGroup",
          "modelWeight",
          "profiles",
          "inclusionRationale"
        ],
        "properties": {
          "rsid": {
            "type": "string",
            "pattern": "^rs[0-9]+$"
          },
          "claimIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "contributionStates": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "enum": [
                "scored",
                "supported_baseline",
                "insufficient_evidence",
                "unsupported_genotype",
                "excluded"
              ]
            }
          },
          "axisMultiplier": {
            "type": "number"
          },
          "mechanism": {
            "type": "string"
          },
          "independenceGroup": {
            "type": "string"
          },
          "modelWeight": {
            "type": "number",
            "minimum": 0
          },
          "profiles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["conservative", "exploratory"]
            }
          },
          "profilesByClaimId": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["conservative", "exploratory"]
              }
            }
          },
          "evidenceConflict": {
            "type": "boolean"
          },
          "inclusionRationale": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "interpretationBands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["min", "max", "label"],
        "properties": {
          "min": { "type": "number" },
          "max": { "type": "number" },
          "label": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
